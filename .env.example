# Copy to .env.local and fill only the values you need.

# Required for AgentPlane + Codex.
OPENAI_API_KEY=

# Optional. Used by Claude Code adapter.
ANTHROPIC_API_KEY=

# Benchmark selection.
BENCHMARK_ENGINE=harbor
DATASET=terminal-bench/terminal-bench-2
LEADERBOARD_DATASET=terminal-bench-core==0.1.1

# Model and run shape.
MODEL=gpt-5-nano
N=1
N_CONCURRENT=1

# If `harbor` is not on PATH, set this to an explicit command such as:
# HARBOR_BIN="uvx harbor"
HARBOR_BIN=harbor

# If `tb` is not on PATH, set this to:
# TB_BIN="uvx terminal-bench"
TB_BIN=tb
